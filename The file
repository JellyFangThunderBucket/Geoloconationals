// ==UserScript==
// @name        Location Guard
// @description A UserScript that hides/spoofs your geographic location from websites.
// @namespace   https://skk.moe
// @run-at      document-end
// @match       *://*/*
// @updateURL   https://unpkg.com/location-guard@latest/dist/location-guard-ng.meta.js
// @downloadURL https://unpkg.com/location-guard@latest/dist/location-guard-ng.user.js
// @version     0.2.3
// @author      Sukka <https://skk.moe>
// @grant       unsafeWindow
// @grant       GM_getValue
// @grant       GM_setValue
// @grant       GM_deleteValue
// @grant       GM_addValueChangeListener
// @grant       GM_removeValueChangeListener
// @grant       GM.getValue
// @grant       GM.setValue
// @grant       GM.deleteValue
// @grant       GM.registerMenuCommand
// @grant       GM.addValueChangeListener
// @grant       GM.removeValueChangeListener
// ==/UserScript==

(function () {
    'use strict';

    const DEFAULT_VALUE = {
        defaultLevel: 'fixed',
        paused: false,
        cachedPos: {},
        fixedPos: {
            latitude: -4.448784,
            longitude: -171.24832
        },
        updateAccuracy: true,
        epsilon: 2,
        levels: {
            low: {
                radius: 200,
                cacheTime: 10
            },
            medium: {
                radius: 500,
                cacheTime: 30
            },
            high: {
                radius: 2000,
                cacheTime: 60
            }
        }
    };

    const gmApi = typeof GM === 'object' && GM !== null ? GM : {};
    const gmGetValue = typeof gmApi.getValue === 'function'
        ? gmApi.getValue.bind(gmApi)
        : (typeof GM_getValue === 'function' ? GM_getValue : null);
    const gmSetValue = typeof gmApi.setValue === 'function'
        ? gmApi.setValue.bind(gmApi)
        : (typeof GM_setValue === 'function' ? GM_setValue : null);

    async function getStoredValueAsync(key, providedDefaultValue) {
        const defaultValue = providedDefaultValue ?? DEFAULT_VALUE[key];

        if (!gmGetValue) {
            return defaultValue;
        }

        return gmGetValue(key, defaultValue);
    }

    async function setStoredValueAsync(key, value) {
        if (!gmSetValue) {
            DEFAULT_VALUE[key] = value;
            return undefined;
        }

        return gmSetValue(key, value);
    }

    function isPlainObject(value) {
        return value !== null && typeof value === 'object' && !Array.isArray(value);
    }

    function getMergedLevels(storedLevels) {
        return {
            ...DEFAULT_VALUE.levels,
            ...(isPlainObject(storedLevels) ? storedLevels : {})
        };
    }

    function normalizePrivacyLevel(level, levels) {
        if (level === 'real' || level === 'fixed' || Object.prototype.hasOwnProperty.call(levels, level)) {
            return level;
        }

        return DEFAULT_VALUE.defaultLevel;
    }

    // Planar Laplace mechanism, based on Marco's demo.
    // This object implements the mechanism only; it does not manage privacy budget
    // or epsilon selection.
    const PlanarLaplace = {
        /** Convert an angle in radians to degrees and vice versa. */
        rad_of_deg(ang) {
            return ang * Math.PI / 180;
        },
        deg_of_rad(ang) {
            return ang * 180 / Math.PI;
        },
        /**
         * Mercator projection
         * https://wiki.openstreetmap.org/wiki/Mercator
         * https://en.wikipedia.org/wiki/Mercator_projection
         *
         * getLatLon and getCartesian are inverse functions. They convert
         * { x, y } and { latitude, longitude } into one another.
         */
        getLatLon({ x, y }) {
            const rLon = x / PlanarLaplace.earth_radius;
            const rLat = 2 * Math.atan(Math.exp(y / PlanarLaplace.earth_radius)) - Math.PI / 2;

            return {
                latitude: PlanarLaplace.deg_of_rad(rLat),
                longitude: PlanarLaplace.deg_of_rad(rLon)
            };
        },
        getCartesian({ longitude, latitude }) {
            return {
                x: PlanarLaplace.earth_radius * PlanarLaplace.rad_of_deg(longitude),
                y: PlanarLaplace.earth_radius * Math.log(Math.tan(Math.PI / 4 + PlanarLaplace.rad_of_deg(latitude) / 2))
            };
        },
        /** Lambert W function on branch -1 (http://en.wikipedia.org/wiki/Lambert_W_function). */
        LambertW(x) {
            const minDiff = 1e-10;

            if (x === -1 / Math.E) {
                return -1;
            }

            if (x < 0 && x > -1 / Math.E) {
                let q = Math.log(-x);
                let p = 1;

                while (Math.abs(p - q) > minDiff) {
                    p = (q * q + x / Math.exp(q)) / (q + 1);
                    q = (p * p + x / Math.exp(p)) / (p + 1);
                }

                return Math.round(1000000 * q) / 1000000;
            }

            return 0;
        },
        /** This is the inverse cumulative polar Laplacian distribution function. */
        inverseCumulativeGamma(epsilon, z) {
            const x = (z - 1) / Math.E;
            return -(PlanarLaplace.LambertW(x) + 1) / epsilon;
        },
        /**
         * Return alpha such that the noisy position is within alpha from the
         * real position with probability at least delta.
         */
        alphaDeltaAccuracy(epsilon, delta) {
            return PlanarLaplace.inverseCumulativeGamma(epsilon, delta);
        },
        expectedError(epsilon) {
            return 2 / epsilon;
        },
        addPolarNoise(epsilon, pos) {
            const theta = Math.random() * Math.PI * 2;
            const z = Math.random();
            const r = PlanarLaplace.inverseCumulativeGamma(epsilon, z);
            return PlanarLaplace.addVectorToPos(pos, r, theta);
        },
        addPolarNoiseCartesian(epsilon, pos) {
            let x;
            let y;

            if ('latitude' in pos) {
                const tmp = PlanarLaplace.getCartesian(pos);
                x = tmp.x;
                y = tmp.y;
            } else {
                x = pos.x;
                y = pos.y;
            }

            const theta = Math.random() * Math.PI * 2;
            const z = Math.random();
            const r = PlanarLaplace.inverseCumulativeGamma(epsilon, z);

            return PlanarLaplace.getLatLon({
                x: x + r * Math.cos(theta),
                y: y + r * Math.sin(theta)
            });
        },
        /** http://www.movable-type.co.uk/scripts/latlong.html */
        addVectorToPos({ latitude, longitude }, distance, angle) {
            const angularDistance = distance / PlanarLaplace.earth_radius;
            const lat1 = PlanarLaplace.rad_of_deg(latitude);
            const lon1 = PlanarLaplace.rad_of_deg(longitude);
            const lat2 = Math.asin(Math.sin(lat1) * Math.cos(angularDistance) + Math.cos(lat1) * Math.sin(angularDistance) * Math.cos(angle));
            let lon2 = lon1 + Math.atan2(Math.sin(angle) * Math.sin(angularDistance) * Math.cos(lat1), Math.cos(angularDistance) - Math.sin(lat1) * Math.sin(lat2));

            lon2 = (lon2 + 3 * Math.PI) % (2 * Math.PI) - Math.PI;

            return {
                latitude: PlanarLaplace.deg_of_rad(lat2),
                longitude: PlanarLaplace.deg_of_rad(lon2)
            };
        },
        /** This function generates the position of a point with Laplacian noise. */
        addNoise(epsilon, pos) {
            return PlanarLaplace.addPolarNoise(epsilon, pos);
        },
        earth_radius: 6378137
    };

    function klona(x) {
        if (typeof x !== 'object' || x === null) return x;

        let k;
        let tmp;
        const str = Object.prototype.toString.call(x);

        if (str === '[object Object]') {
            if (x.constructor !== Object && typeof x.constructor === 'function') {
                tmp = new x.constructor();
                for (k in x) {
                    if (Object.prototype.hasOwnProperty.call(x, k) && tmp[k] !== x[k]) {
                        tmp[k] = klona(x[k]);
                    }
                }
            } else {
                tmp = {};
                for (k in x) {
                    if (k === '__proto__') {
                        Object.defineProperty(tmp, k, {
                            value: klona(x[k]),
                            configurable: true,
                            enumerable: true,
                            writable: true
                        });
                    } else {
                        tmp[k] = klona(x[k]);
                    }
                }
            }
            return tmp;
        }

        if (str === '[object Array]') {
            k = x.length;
            tmp = Array(k);
            while (k--) {
                tmp[k] = klona(x[k]);
            }
            return tmp;
        }

        if (str === '[object Date]') {
            return new Date(+x);
        }

        if (str === '[object RegExp]') {
            tmp = new RegExp(x.source, x.flags);
            tmp.lastIndex = x.lastIndex;
            return tmp;
        }

        return x;
    }

    const mobilePattern = /android|webos|iphone|ipad|ipod|blackberry|iemobile|opera mini/i;
    let isMobile = null;

    const isMobileDevice = () => {
        if (isMobile !== null) return isMobile;

        isMobile = mobilePattern.test(window.navigator.userAgent);
        return isMobile;
    };

    function randomInt(from, to) {
        return Math.floor(Math.random() * (to - from + 1)) + from;
    }

    function buildFixedPosition(position) {
        const { latitude, longitude } = isPlainObject(position) ? position : DEFAULT_VALUE.fixedPos;

        return {
            coords: {
                latitude,
                longitude,
                accuracy: 10,
                altitude: isMobileDevice() ? randomInt(10, 100) : null,
                altitudeAccuracy: isMobileDevice() ? 10 : null,
                heading: isMobileDevice() ? randomInt(0, 360) : null,
                speed: null
            },
            timestamp: Date.now()
        };
    }

    function clonePosition(position) {
        if (!position || !position.coords) {
            return klona(position);
        }

        return {
            coords: {
                latitude: position.coords.latitude,
                longitude: position.coords.longitude,
                accuracy: position.coords.accuracy,
                altitude: position.coords.altitude,
                altitudeAccuracy: position.coords.altitudeAccuracy,
                heading: position.coords.heading,
                speed: position.coords.speed
            },
            timestamp: position.timestamp
        };
    }

    function cloneError(error) {
        if (!error || typeof error !== 'object') {
            return error;
        }

        return {
            code: error.code,
            message: error.message,
            PERMISSION_DENIED: error.PERMISSION_DENIED,
            POSITION_UNAVAILABLE: error.POSITION_UNAVAILABLE,
            TIMEOUT: error.TIMEOUT
        };
    }

    if (!navigator.geolocation) {
        return;
    }

    const watchPosition = navigator.geolocation.watchPosition;
    const getCurrentPosition = navigator.geolocation.getCurrentPosition;
    const clearWatch = navigator.geolocation.clearWatch;

    async function callGeoCb(cb, arg, checkAllowed) {
        if (typeof cb === 'function' && (!checkAllowed || await isWatchAllowed())) {
            cb(arg);
        }
    }

    function replaceGeolocationMethod(method, replacement) {
        try {
            Object.defineProperty(navigator.geolocation, method, {
                value: replacement,
                configurable: true,
                writable: true
            });
        } catch (_error) {
            navigator.geolocation[method] = replacement;
        }
    }

    const spoofLocation = () => {
        const handlers = new Map();
        const clearedHandlers = new Set();
        let nextHandler = 1;

        replaceGeolocationMethod('getCurrentPosition', async function (positionCb, positionOnError, options) {
            const res = await getNoisyPosition(options);
            if (res.success) {
                callGeoCb(positionCb, res.position, false);
            } else {
                callGeoCb(positionOnError, res.position, false);
            }
        });

        replaceGeolocationMethod('watchPosition', function (cb1, cb2, options) {
            const handler = nextHandler++;

            (async () => {
                if (clearedHandlers.has(handler)) {
                    return;
                }

                if (await isWatchAllowed()) {
                    const nativeHandler = watchPosition.call(
                        navigator.geolocation,
                        (position) => callGeoCb(cb1, position, true),
                        (error) => callGeoCb(cb2, error, true),
                        options
                    );

                    if (clearedHandlers.has(handler)) {
                        clearWatch.call(navigator.geolocation, nativeHandler);
                        clearedHandlers.delete(handler);
                    } else {
                        handlers.set(handler, nativeHandler);
                    }
                } else {
                    navigator.geolocation.getCurrentPosition(cb1, cb2, options);
                }
            })();

            return handler;
        });

        replaceGeolocationMethod('clearWatch', function (handler) {
            if (handlers.has(handler)) {
                clearWatch.call(navigator.geolocation, handlers.get(handler));
                handlers.delete(handler);
                return;
            }

            clearedHandlers.add(handler);
        });
    };

    const inFrame = window !== window.top;

    async function isWatchAllowed() {
        const levels = getMergedLevels(await getStoredValueAsync('levels'));
        const level = normalizePrivacyLevel(await getStoredValueAsync('defaultLevel'), levels);
        const paused = await getStoredValueAsync('paused');
        return !inFrame && (paused || level === 'real');
    }

    async function getNoisyPosition(opt) {
        const levels = getMergedLevels(await getStoredValueAsync('levels'));
        const level = normalizePrivacyLevel(await getStoredValueAsync('defaultLevel'), levels);
        const paused = await getStoredValueAsync('paused');

        if (!paused && level === 'fixed') {
            const fixedPos = await getStoredValueAsync('fixedPos');
            return {
                success: true,
                position: buildFixedPosition(fixedPos)
            };
        }

        return new Promise((resolve) => {
            getCurrentPosition.call(
                navigator.geolocation,
                async function (position) {
                    const noisy = await addNoise(clonePosition(position));
                    resolve({
                        success: true,
                        position: noisy
                    });
                },
                function (error) {
                    resolve({
                        success: false,
                        position: cloneError(error)
                    });
                },
                opt
            );
        });
    }

    // Gets a position and returns a noisy version based on the privacy options.
    async function addNoise(position) {
        const paused = await getStoredValueAsync('paused');
        const levels = getMergedLevels(await getStoredValueAsync('levels'));
        const level = normalizePrivacyLevel(await getStoredValueAsync('defaultLevel'), levels);

        if (paused || level === 'real') {
            return position;
        }

        if (level === 'fixed') {
            const fixedPos = await getStoredValueAsync('fixedPos');
            return buildFixedPosition(fixedPos);
        }

        const storedCachedPos = await getStoredValueAsync('cachedPos');
        const cachedPos = isPlainObject(storedCachedPos) ? storedCachedPos : {};
        const storedEpsilon = await getStoredValueAsync('epsilon');
        const cachedLevel = cachedPos[level];

        if (cachedLevel && (Date.now() - cachedLevel.epoch) / 60000 < cachedLevel.cacheTime) {
            return cachedLevel.position;
        }

        const epsilon = storedEpsilon / levels[level].radius;
        const noisy = PlanarLaplace.addNoise(epsilon, position.coords);
        position.coords.latitude = noisy.latitude;
        position.coords.longitude = noisy.longitude;

        if (position.coords.accuracy && await getStoredValueAsync('updateAccuracy')) {
            position.coords.accuracy += Math.round(PlanarLaplace.alphaDeltaAccuracy(epsilon, 0.9));
        }

        position.coords.altitude = null;
        position.coords.altitudeAccuracy = null;
        position.coords.heading = null;
        position.coords.speed = null;

        cachedPos[level] = {
            epoch: Date.now(),
            position,
            cacheTime: levels[level].cacheTime
        };
        await setStoredValueAsync('cachedPos', cachedPos);

        return position;
    }

    const renderConfigUI = async () => {
        const scriptWindow = typeof unsafeWindow !== 'undefined' ? unsafeWindow : window;
        const $locationGuard = {
            ready: true,
            PlanarLaplace,
            epsilon: await getStoredValueAsync('epsilon'),
            emptyCachedPos() {
                return setStoredValueAsync('cachedPos', {});
            },
            setValue: setStoredValueAsync,
            getValue: getStoredValueAsync,
            async resetConfig() {
                const keys = Object.keys(DEFAULT_VALUE);
                await Promise.all(keys.map((key) => setStoredValueAsync(key, klona(DEFAULT_VALUE[key]))));
            }
        };

        Object.defineProperty(scriptWindow, '$locationGuard', {
            value: $locationGuard,
            enumerable: true,
            configurable: true,
            writable: false
        });
        scriptWindow.dispatchEvent(new CustomEvent('location-guard-config-ui-ready'));
    };

    (() => {
        spoofLocation();

        if (typeof gmApi.registerMenuCommand === 'function') {
            gmApi.registerMenuCommand('Configuration', () => {
                const a = document.createElement('a');
                a.href = 'https://location-guard-ng.skk.moe/options';
                a.target = '_blank';
                a.rel = 'noopener noreferrer';
                a.style.display = 'none';
                document.body.appendChild(a);
                a.click();
                a.remove();
            });
        }

        if (window.location.host === 'localhost:3000' || window.location.host === 'location-guard-ng.skk.moe') {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', renderConfigUI, { once: true });
            } else {
                renderConfigUI();
            }
        }
    })();
})();
